nano style.css
body {
    margin: 0;
    font-family: sans-serif;
    background: #121212;
    color: white;
    text-align: center;
}

nav {
    background: #1f1f1f;
    padding: 10px;
    display: flex;
    justify-content: space-around;
    align-items: center;
}

.hero {
    padding: 100px 20px;
}

button {
    background: #00ff88;
    color: black;
    border: none;
    padding: 15px 30px;
    font-size: 18px;
    border-radius: 50px;
    font-weight: bold;
}

